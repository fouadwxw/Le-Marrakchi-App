# === MongoDB Atlas ===
# Créer un cluster gratuit M0 sur https://cloud.mongodb.com puis coller l'URI de connexion ici
MONGO_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="le_marrakechi"

# === Sécurité JWT ===
# N'importe quelle chaîne aléatoire longue (génère-la avec la commande fournie dans le guide)
JWT_SECRET="change-me-avec-une-vraie-cle-secrete"

# === IA (optionnel) ===
# La clé Emergent d'origine ne fonctionnera pas hors de leur plateforme.
# Laisser vide pour désactiver l'assistant IA, ou mettre ta propre clé OpenAI/Anthropic
# si tu adaptes le code d'appel dans server.py (recherche EMERGENT_LLM_KEY).
EMERGENT_LLM_KEY=""
